<% layout('/layouts/boilerplate') -%>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <b>
                <%= list.title %>
            </b>

            <div class=" listing-card">
                <img src="<%= list.image.url %>" class="card-img-top size" alt="...">
                <div class="card-body">
                    <p class="card-text mt-3">
                        <hr />
                        <i>Owned by <%= list.owner.username %></i><br />
                        <%= list.description %><br />
                            <%= list.location %><br />
                                <%= list.country %><br />
                                    &#8377; <%= list.price.toLocaleString("en-IN") %>
                                        <br />
                    </p>
                </div>
            </div>
            <br>

        </div>
        <% if(currentUser && currentUser._id.equals(list.owner._id)) { %>
            <div class="d-flex offset-2  gap-2 mb-3">
                <a href="/listings/<%= list._id %>/edit" class="btn btn-danger">Edit</a>
                <form method="POST" action="/listings/<%= list._id %>?_method=DELETE">
                    <button class="btn btn-dark">Delete</button>
                </form>
            </div>
            <% } %>
                <hr />
                <div class="col-8 offset-2">
                    <% if(currentUser){ %>
                        <h4>Leave a review</h4>
                        <form action="/listings/<%= list._id %>/reviews" method="POST" class="needs-validation"
                            novalidate>

                            <div class="mb-3 mt-3">
                                <fieldset class="starability-growRotate">
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" required />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>
                            <div>
                                <label for="comment" class="form-label">Comments</label>
                                <textarea name="review[comment]" id="comment" class="form-control" required></textarea>
                                <div class="invalid-feedback">Please submit some comments for review</div>
                            </div>
                            <button class="btn btn-primary mt-2">Submit Review</button>
                        </form>
                        
                        <hr />
                        <% } %>
                            <% if (list.reviews.length !=0) { %>
                                <h4 class="col-6 ">All Reviews</h4>
                                <div class="row ">
                                    <% for(reviews of list.reviews) { %>
                                        <div class="card col-5 mb-3 ms-3 ">
                                            <h5 class="card-title">@<%= reviews.author.username %>
                                            </h5>
                                            <p class="card-text">
                                                <%= reviews.comment %>
                                            </p>

                                            <p class="starability-result" data-rating="<%= reviews.rating %>">
                                            </p>
                                            <form class="mb-3" method="POST"
                                                action="/listings/<%= list._id %>/reviews/<%= reviews._id %>?_method=DELETE">
                                                <button class="btn btn-sm btn-dark">Delete</button>
                                            </form>
                                        </div>
                                        <% } %>
                                    </div>
                </div>
                <% } %>
    </div>

    <h3 class="col-6 offset-2">You'll be there</h3>
        <div id="map" style="height: 400px;" class="col-6 offset-2 mb-3"></div>
<script>
  const lng = <%= list.geometry.coordinates[0] %>;
  const lat = <%= list.geometry.coordinates[1] %>;

  const map = new maplibregl.Map({
    container: 'map',
    style: 'https://demotiles.maplibre.org/style.json',
    center: [lng, lat],
    zoom: 5
  });

  // Add zoom controls
  map.addControl(new maplibregl.NavigationControl());

  // ✅ Add marker
  new maplibregl.Marker({ color: "red" })
    .setLngLat([lng, lat])
    .addTo(map);
</script>
